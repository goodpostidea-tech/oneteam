{
  "name": "oneteam-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:backend": "cd ../backend && node esbuild.config.mjs",
    "build:seed": "cd ../backend && node scripts/build-seed-db.mjs",
    "build:all": "node scripts/build-all.mjs",
    "dist:win": "node scripts/dist-win.mjs",
    "dist:mac": "node scripts/dist-mac.mjs",
    "start": "electron ."
  },
  "build": {
    "appId": "com.oneteam.desktop",
    "productName": "OneTeam",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/bundle",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/node_modules/@prisma/client",
        "to": "backend/node_modules/@prisma/client",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/node_modules/.prisma/client",
        "to": "backend/node_modules/.prisma/client",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/desktop_logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/desktop_logo.png",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@milkdown/kit": "^7.19.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  }
}
